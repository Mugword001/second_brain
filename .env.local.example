# ───────────────────────────────────────────────
# このファイルを「.env.local」という名前でコピーして、値を入れてください。
# .env.local は絶対にGitHubに上げないこと（.gitignoreで除外済み）
#
# ⚠️ APIキーの契約・管理・支払いは「18歳以上」が必須です。
#    お母さん名義で取得・管理してください。
# ───────────────────────────────────────────────

# Supabase（supabase.com → Project Settings → API）
NEXT_PUBLIC_SUPABASE_URL=https://xxxxx.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=ここに anon public キーを貼る

# Anthropic（console.anthropic.com で取得。Phase 1 の読み取りで使う）
# ※ ここが空の間は、アプリは「お試しモード（ダミーの結果）」で動きます。
#    キーを入れると、本物のClaudeが読み取るようになります。
ANTHROPIC_API_KEY=
